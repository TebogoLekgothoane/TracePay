# Copy this file to an uncommitted mobile/.env file for local development.
# Then restart Expo: npx expo start

# Backend API (voice chat, analyze, open banking)
# Same machine: http://localhost:8001
# Android emulator: http://10.0.2.2:8001
# Physical device on the same Wi-Fi: http://YOUR_PC_IP:8001
EXPO_PUBLIC_BACKEND_URL=http://localhost:8001

# Voice chat uses Groq via the backend. Configure GROQ_API_KEY as a backend deployment secret.
# Do not put server-side provider secrets in the mobile app.

